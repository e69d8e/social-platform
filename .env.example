# ===========================================
# Social Platform 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ===========================================

# MySQL / Redis / JWT 共用密码
PASSWORD=your_password_here

# DashScope AI (通义千问) API Key
DASH_SCOPE_API_KEY=your_dashscope_api_key_here

# Nginx 静态图片目录（上传图片存储路径）
IMAGE_PATH=/usr/local/nginx/html/imgs

# 跨域允许来源（可选，默认 http://127.0.0.1:5173）
# CORS_ORIGIN=http://127.0.0.1:5173
